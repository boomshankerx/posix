{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#a7b2c8",
          "foreground": "#222222",
          "leading_powerline_symbol": "",
          "powerline_symbol": "",
          "style": "powerline",
          "template": "{{ if .WSL }}WSL at {{ end }}{{.Icon}} ",
          "type": "os"
        },
        {
          "background": "#0077c2",
          "foreground": "#ffffff",
          "options": {},
          "powerline_symbol": "",
          "style": "powerline",
          "template": " {{.UserName}}@{{ .HostName }} ",
          "type": "shell"
        },
        {
          "background": "#ef5350",
          "foreground": "#FFFB38",
          "powerline_symbol": "",
          "style": "powerline",
          "template": "💀",
          "type": "root"
        },
        {
          "background": "#aab3c4",
          "foreground": "#2d3436",
          "options": {
            "folder_icon": "  ",
            "home_icon": "",
            "style": "full"
          },
          "powerline_symbol": "",
          "style": "powerline",
          "template": "  {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#7d97c6",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ffffff{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#c5e478{{ end }}",
            "{{ if gt .Ahead 0 }}#C792EA{{ end }}",
            "{{ if gt .Behind 0 }}#C792EA{{ end }}"
          ],
          "foreground": "#011627",
          "options": {
            "branch_icon": " ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "diamond",
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<#ef5350>  {{ .Staging.String }}</>{{ end }} ",
          "trailing_diamond": "",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "overflow": "hide",
      "segments": [
        {
          "background": "#6c727e",
          "foreground": "#ffffff",
          "leading_powerline_symbol": "",
          "options": {
            "style": "roundrock",
            "threshold": 0
          },
          "powerline_symbol": "",
          "style": "powerline",
          "template": "  {{ .FormattedMs }}⠀",
          "type": "executiontime"
        },
        {
          "background": "#303030",
          "foreground": "#3C873A",
          "options": {
            "fetch_package_manager": true,
            "npm_icon": " <#cc3a3a></> ",
            "yarn_icon": " <#348cba></>"
          },
          "powerline_symbol": "",
          "style": "powerline",
          "template": " {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }}",
          "type": "node"
        },
        {
          "background": "#306998",
          "foreground": "#FFE873",
          "powerline_symbol": "",
          "style": "powerline",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }}",
          "type": "python"
        },
        {
          "background": "#0e8ac8",
          "foreground": "#ffffff",
          "powerline_symbol": "",
          "style": "powerline",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "java"
        },
        {
          "background": "#0e0e0e",
          "foreground": "#0d6da8",
          "powerline_symbol": "",
          "style": "powerline",
          "template": " {{ if .Unsupported }}{{ else }}{{ .Full }}{{ end }}",
          "type": "dotnet"
        },
        {
          "background": "#ffffff",
          "foreground": "#06aad5",
          "powerline_symbol": "",
          "style": "powerline",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "go"
        },
        {
          "background": "#f3f0ec",
          "foreground": "#925837",
          "powerline_symbol": "",
          "style": "powerline",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "rust"
        },
        {
          "background": "#e1e8e9",
          "foreground": "#055b9c",
          "powerline_symbol": "",
          "style": "powerline",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "dart"
        },
        {
          "background": "#ffffff",
          "foreground": "#ce092f",
          "powerline_symbol": "",
          "style": "powerline",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "angular"
        },
        {
          "background": "#1e293b",
          "foreground": "#ffffff",
          "powerline_symbol": "",
          "style": "powerline",
          "template": "{{ if .Error }}{{ .Error }}{{ else }}Nx {{ .Full }}{{ end }}",
          "type": "nx"
        },
        {
          "background": "#945bb3",
          "foreground": "#359a25",
          "powerline_symbol": "",
          "style": "powerline",
          "template": "<#ca3c34></> {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "julia"
        },
        {
          "background": "#ffffff",
          "foreground": "#9c1006",
          "powerline_symbol": "",
          "style": "powerline",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "ruby"
        },
        {
          "background": "#ffffff",
          "foreground": "#5398c2",
          "powerline_symbol": "",
          "style": "powerline",
          "template": "<#f5bf45></> {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "azfunc"
        },
        {
          "background": "#565656",
          "foreground": "#faa029",
          "powerline_symbol": "",
          "style": "powerline",
          "template": " {{.Profile}}{{if .Region}}@{{.Region}}{{end}}",
          "type": "aws"
        },
        {
          "background": "#316ce4",
          "foreground": "#ffffff",
          "powerline_symbol": "",
          "style": "powerline",
          "template": " {{.Context}}{{if .Namespace}} :: {{.Namespace}}{{end}}",
          "type": "kubectl"
        },
        {
          "background": "#f36943",
          "background_templates": [
            "{{if eq \"Charging\" .State.String}}#b8e994{{end}}",
            "{{if eq \"Discharging\" .State.String}}#fff34e{{end}}",
            "{{if eq \"Full\" .State.String}}#33DD2D{{end}}"
          ],
          "foreground": "#262626",
          "invert_powerline": true,
          "options": {
            "charged_icon": " ",
            "charging_icon": " ",
            "discharging_icon": " "
          },
          "powerline_symbol": "",
          "style": "powerline",
          "template": " {{ if not .Error }}{{ .Icon }}{{ .Percentage }}{{ end }}{{ .Error }} ",
          "type": "battery"
        },
        {
          "background": "#a7b2c8",
          "foreground": "#222222",
          "options": {
            "time_format": "1-2 15:04"
          },
          "style": "diamond",
          "template": "  {{ .CurrentDate | date .Format }} ",
          "trailing_diamond": "",
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#ffffff",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#ef5350{{ end }}"
          ],
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "$ ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 3
}