#!/usr/bin/env bash

curl -JLo /tmp/code.deb "https://code.visualstudio.com/sha/download?build=stable&os=linux-deb-x64"
sudo dpkg -i /tmp/code.deb
rm /tmp/code.deb

case $XDG_CURRENT_DESKTOP in
"XFCE")
  # Ensure the file and directory exist
  mkdir -p ~/.config/Thunar
  touch ~/.config/Thunar/uca.xml   # creates empty file if missing

  # Open VSCode Here action (for directories)
  if ! grep -q "Open VSCode Here" ~/.config/Thunar/uca.xml; then
    # Insert the new action right after the opening <actions> tag (prepends to top)
    sed -i '/<actions>/a \
    <action>\
      <icon>vscode</icon>\
      <name>Open VSCode Here</name>\
      <description>Open VSCode in this directory</description>\
      <unique-id>vscode-folder</unique-id>\
      <command>code %f</command>\
      <patterns>*</patterns>\
      <range>*</range>\
      <directories/>\
    </action>' ~/.config/Thunar/uca.xml
  fi

  # Open in VSCode action (for files)
  if ! grep -q "Open with VSCode" ~/.config/Thunar/uca.xml; then
  sed -i '/<actions>/a \
  <action>\
    <icon>vscode</icon>\
    <name>Open with VSCode</name>\
    <description>Open selected files with VSCode</description>\
    <unique-id>vscode-file</unique-id>\
    <command>code %F</command>\
    <patterns>*</patterns>\
    <range>*</range>\
    <directories/>\
    <other-files/>\
    <text-files/>\
  </action>' ~/.config/Thunar/uca.xml
  fi  
esac  